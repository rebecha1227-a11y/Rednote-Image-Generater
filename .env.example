# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OPENAI_API_KEY: Optional. Used for any OpenAI-compatible provider (DeepSeek, etc.)
OPENAI_API_KEY=""
# OPENAI_BASE_URL: e.g., https://api.deepseek.com/v1
OPENAI_BASE_URL=""
# OPENAI_MODEL_NAME: e.g., deepseek-chat
OPENAI_MODEL_NAME=""

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
